# Dependencies
node_modules/
# Only ignore root-level lock file; frontend/package-lock.json must be committed
# so `npm ci` works in the Docker build stage
/package-lock.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/

# ============================================================
# Secret / Sensitive files — NEVER commit these
# ============================================================

# Environment variables (keep .env.example as the safe template)
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local
backend/.env
backend/.env.local

# ============================================================
# User data — JSON files may contain PII / financial records
# ============================================================
backend/data/users.json
backend/data/transactions.json
backend/data/predictions.json

# ============================================================
# Rust engine build artifacts
# ============================================================
backend/engine/target/

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
logs/
*.log
npm-debug.log*

# Build output
dist/
build/
.cache/

# Temporary files
*.tmp
*.temp
.temp/
.tmp/

# Deployment archives
*.zip
*.tar.gz
