  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.6",
    "pg": "^8.11.3",
    "rustup": "^1.0.10",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "directories": {
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annavajhula10/samsa.git"
  },
