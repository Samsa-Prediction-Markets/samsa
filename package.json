{
  "name": "samsa",
  "version": "1.0.0",
  "description": "Samsa Prediction Markets - Full Stack Application",
  "private": true,
  "scripts": {
    "start": "npm run backend:start",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build",
    "start:prod": "npm run frontend:build && npm run backend:start",
    "backend:start": "node backend/server.js",
    "backend:dev": "nodemon backend/server.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "test": "node --test ./tests/*.test.js",
    "migrate": "node scripts/migrate-json-to-db.js",
    "db:init": "psql -d samsa_dev -f backend/lib/database/schema.sql",
    "build:engine": "cd backend/engine && cargo +stable-x86_64-pc-windows-gnu build --release",
    "test:engine": "cd backend/engine && cargo +stable-x86_64-pc-windows-gnu test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dome-api/sdk": "^0.0.8",
    "@supabase/supabase-js": "^2.103.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.6",
    "pg": "^8.11.3",
    "sequelize": "6.37.8",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "autocannon": "^2.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  },
  "directories": {
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annavajhula10/samsa.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/annavajhula10/samsa/issues"
  },
  "homepage": "https://github.com/annavajhula10/samsa#readme",
  "overrides": {
    "uuid": "^9.0.0"
  }
}
