import { NextRequest } from "next/server";
import { prisma } from "@/lib/prisma";
import { getAuthUser } from "@/lib/auth";

export async function GET(_req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
  const { id } = await params;
  const market = await prisma.market.findUnique({ where: { id }, include: { outcomes: true, _count: { select: { predictions: true } } } });
  if (!market) return Response.json({ error: "Market not found" }, { status: 404 });
  return Response.json({ market });
}

export async function POST(req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
  const auth = await getAuthUser();
  if (!auth) return Response.json({ error: "Unauthorized" }, { status: 401 });
  const { id } = await params;
  const { winOutcomeId } = await req.json();
  if (!winOutcomeId) return Response.json({ error: "winOutcomeId is required" }, { status: 400 });
  const market = await prisma.market.findUnique({ where: { id }, include: { outcomes: true, predictions: true } });
  if (!market) return Response.json({ error: "Market not found" }, { status: 404 });
  if (market.status !== "active") return Response.json({ error: "Market already resolved" }, { status: 400 });
  if (!market.outcomes.find((o) => o.id === winOutcomeId)) return Response.json({ error: "Invalid winOutcomeId" }, { status: 400 });
  await prisma.$transaction(async (tx) => {
    await tx.market.update({ where: { id }, data: { status: "resolved", resolvedAt: new Date(), winOutcomeId } });
    for (const pred of market.predictions) {
      if (pred.status !== "open") continue;
      const won = pred.outcomeId === winOutcomeId;
      const payout = won ? pred.amount / pred.entryProb : 0;
      await tx.prediction.update({ where: { id: pred.id }, data: { status: won ? "won" : "lost", payout } });
      if (won && payout > 0) {
        await tx.user.update({ where: { id: pred.userId }, data: { balance: { increment: payout } } });
        await tx.transaction.create({ data: { userId: pred.userId, type: "payout", amount: payout, note: `Won: ${market.title}` } });
      }
    }
  });
  return Response.json({ ok: true });
} 
