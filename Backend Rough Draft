import { NextRequest } from "next/server";
import { prisma } from "@/lib/prisma";
import { getAuthUser } from "@/lib/auth";
import { lmsrBuy, lmsrProbabilities } from "@/lib/lmsr";

export async function GET(req: NextRequest) {
  const auth = await getAuthUser();
  if (!auth) return Response.json({ error: "Unauthorized" }, { status: 401 });
  const marketId = new URL(req.url).searchParams.get("marketId");
  const predictions = await prisma.prediction.findMany({
    where: { userId: auth.userId, ...(marketId ? { marketId } : {}) },
    include: { market: { select: { title: true, status: true, category: true } }, outcome: { select: { label: true } } },
    orderBy: { createdAt: "desc" },
  });
  return Response.json({ predictions });
}

export async function POST(req: NextRequest) {
  const auth = await getAuthUser();
  if (!auth) return Response.json({ error: "Unauthorized" }, { status: 401 });
  try {
    const { marketId, outcomeId, amount } = await req.json();
    if (!marketId || !outcomeId || !amount) return Response.json({ error: "marketId, outcomeId, amount required" }, { status: 400 });
    const betAmount = parseFloat(amount);
    if (isNaN(betAmount) || betAmount <= 0) return Response.json({ error: "amount must be positive" }, { status: 400 });
    const prediction = await prisma.$transaction(async (tx) => {
      const user = await tx.user.findUnique({ where: { id: auth.userId } });
      if (!user) throw new Error("User not found");
      if (user.balance < betAmount) throw new Error("Insufficient balance");
      const market = await tx.market.findUnique({ where: { id: marketId }, include: { outcomes: true } });
      if (!market) throw new Error("Market not found");
      if (market.status !== "active") throw new Error("Market is not active");
      if (new Date() > market.closeAt) throw new Error("Market is closed");
      const outcome = market.outcomes.find((o) => o.id === outcomeId);
      if (!outcome) throw new Error("Outcome not found");
      const sharesArr = market.outcomes.map((o) => o.shares);
      const outcomeIdx = market.outcomes.findIndex((o) => o.id === outcomeId);
      const { shares, newProbability, newShares } = lmsrBuy(sharesArr, market.liquidity, outcomeIdx, betAmount);
      const newProbs = lmsrProbabilities(newShares, market.liquidity);
      await tx.user.update({ where: { id: auth.userId }, data: { balance: { decrement: betAmount } } });
      for (let i = 0; i < market.outcomes.length; i++)
        await tx.outcome.update({ where: { id: market.outcomes[i].id }, data: { shares: newShares[i], probability: newProbs[i] * 100 } });
      await tx.market.update({ where: { id: marketId }, data: { volume: { increment: betAmount }, probability: newProbability * 100 } });
      await tx.transaction.create({ data: { userId: auth.userId, type: "bet", amount: -betAmount, note: `Bet on "${outcome.label}" in "${market.title}"` } });
      return tx.prediction.create({ data: { userId: auth.userId, marketId, outcomeId, amount: betAmount, shares, entryProb: newProbability, status: "open" }, include: { outcome: { select: { label: true } }, market: { select: { title: true } } } });
    });
    return Response.json({ prediction }, { status: 201 });
  } catch (err: unknown) {
    const msg = err instanceof Error ? err.message : "Failed to place bet";
    return Response.json({ error: msg }, { status: msg === "Insufficient balance" || msg.includes("not active") || msg.includes("closed") ? 400 : msg.includes("not found") ? 404 : 500 });
  }
} 
