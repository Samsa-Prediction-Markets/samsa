import { NextRequest } from "next/server";
import bcrypt from "bcryptjs";
import { prisma } from "@/lib/prisma";
import { signToken } from "@/lib/auth";

export async function POST(req: NextRequest) {
  try {
    const { email, username, password } = await req.json();
    if (!email || !username || !password)
      return Response.json({ error: "email, username, and password required" }, { status: 400 });
    if (password.length < 6)
      return Response.json({ error: "Password must be at least 6 characters" }, { status: 400 });

    const existing = await prisma.user.findFirst({ where: { OR: [{ email }, { username }] } });
    if (existing)
      return Response.json({ error: "Email or username already taken" }, { status: 409 });

    const passwordHash = await bcrypt.hash(password, 10);
    const user = await prisma.user.create({
      data: { email, username, passwordHash, balance: 1000 },
      select: { id: true, email: true, username: true, balance: true },
    });

    const token = await signToken({ userId: user.id, email: user.email, username: user.username });
    const res = Response.json({ user, token }, { status: 201 });
    res.headers.set("Set-Cookie", `token=${token}; HttpOnly; Path=/; Max-Age=604800; SameSite=Lax`);
    return res;
  } catch (err) {
    console.error(err);
    return Response.json({ error: "Registration failed" }, { status: 500 });
  }
} 
