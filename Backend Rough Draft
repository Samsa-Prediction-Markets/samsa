export function lmsrProbabilities(shares: number[], b: number): number[] {
  const exps = shares.map((s) => Math.exp(s / b));
  const total = exps.reduce((a, e) => a + e, 0);
  return exps.map((e) => e / total);
}

export function lmsrBuy(shares: number[], b: number, outcomeIdx: number, amount: number) {
  const prob = lmsrProbabilities(shares, b)[outcomeIdx];
  const purchased = amount / Math.max(prob, 0.01);
  const newSharesArr = shares.map((s, i) => i === outcomeIdx ? s + purchased : s);
  const newProbs = lmsrProbabilities(newSharesArr, b);
  return { shares: purchased, newProbability: newProbs[outcomeIdx], newShares: newSharesArr };
} 
