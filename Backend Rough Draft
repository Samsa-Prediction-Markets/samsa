import { NextRequest } from "next/server";
import { prisma } from "@/lib/prisma";
import { getAuthUser } from "@/lib/auth";

export async function GET(req: NextRequest) {
  const { searchParams } = new URL(req.url);
  const category = searchParams.get("category");
  const status = searchParams.get("status") || "active";
  const limit = Math.min(parseInt(searchParams.get("limit") || "20"), 100);
  const markets = await prisma.market.findMany({
    where: { ...(status !== "all" ? { status } : {}), ...(category ? { category } : {}) },
    include: { outcomes: true },
    orderBy: { volume: "desc" },
    take: limit,
  });
  return Response.json({ markets });
}

export async function POST(req: NextRequest) {
  const auth = await getAuthUser();
  if (!auth) return Response.json({ error: "Unauthorized" }, { status: 401 });
  try {
    const { title, description, category, subcategory, closeAt, outcomes } = await req.json();
    if (!title || !description || !category || !closeAt || !outcomes)
      return Response.json({ error: "Missing required fields" }, { status: 400 });
    if (!Array.isArray(outcomes) || outcomes.length < 2)
      return Response.json({ error: "At least 2 outcomes required" }, { status: 400 });
    const closeDate = new Date(closeAt);
    if (isNaN(closeDate.getTime()) || closeDate <= new Date())
      return Response.json({ error: "closeAt must be a valid future date" }, { status: 400 });
    const initialProb = 100 / outcomes.length;
    const market = await prisma.market.create({
      data: {
        title: String(title).slice(0, 300),
        description: String(description).slice(0, 2000),
        category: String(category).slice(0, 50),
        subcategory: String(subcategory || "").slice(0, 50),
        closeAt: closeDate,
        probability: initialProb,
        outcomes: { create: outcomes.map((label: string) => ({ label: String(label).slice(0, 100), probability: initialProb })) },
      },
      include: { outcomes: true },
    });
    return Response.json({ market }, { status: 201 });
  } catch (err) {
    console.error(err);
    return Response.json({ error: "Failed to create market" }, { status: 500 });
  }
}
