File 5 — js/features/auth/login.js
This is the JavaScript logic for login.html — handles username lookup and password login


'use strict';

let loginEmail = '';

// PAGE 3: Look up username and move to password page
document.getElementById('form-login-id').addEventListener('submit', async (e) => {
  e.preventDefault();

  const username = document.getElementById('login-username').value.trim().toLowerCase();
  const errorEl  = document.getElementById('login-id-error');
  const btn      = e.target.querySelector('button');

  errorEl.textContent = '';
  btn.disabled        = true;
  btn.textContent     = 'Checking...';

  try {
    // Look up profile by username
    const { data: profile, error } = await window.supabaseClient
      .from('profiles')
      .select('id, first_name')
      .eq('username', username)
      .maybeSingle();

    if (error || !profile) {
      errorEl.textContent = 'Username not found.';
      btn.disabled        = false;
      btn.textContent     = 'Continue';
      return;
    }

    // Get email from server
    const res  = await fetch(`/api/auth/email-by-username?username=${encodeURIComponent(username)}`);
    const data = await res.json();

    if (!res.ok || !data.email) {
      errorEl.textContent = 'Username not found.';
      btn.disabled        = false;
      btn.textContent     = 'Continue';
      return;
    }

    loginEmail = data.email;

    // Show password page
    document.getElementById('welcome-name').textContent    = `Welcome back, ${profile.first_name}`;
    document.getElementById('page-login-id').style.display = 'none';
    document.getElementById('page-password').style.display = 'block';

  } catch (err) {
    errorEl.textContent = 'Something went wrong. Please try again.';
    btn.disabled        = false;
    btn.textContent     = 'Continue';
  }
});

// PAGE 4: Log in with password
document.getElementById('form-password').addEventListener('submit', async (e) => {
  e.preventDefault();

  const password = document.getElementById('login-password').value;
  const errorEl  = document.getElementById('password-error');
  const btn      = e.target.querySelector('button');

  errorEl.textContent = '';
  btn.disabled        = true;
  btn.textContent     = 'Logging in...';

  try {
    const { error } = await window.supabaseClient.auth.signInWithPassword({
      email:    loginEmail,
      password,
    });

    if (error) {
      errorEl.textContent = 'Incorrect password. Please try again.';
      btn.disabled        = false;
      btn.textContent     = 'Continue';
      return;
    }

    // Redirect to dashboard
    window.location.href = '../index.html';

  } catch (err) {
    errorEl.textContent = 'Something went wrong. Please try again.';
    btn.disabled        = false;
    btn.textContent     = 'Continue';
  }
});
