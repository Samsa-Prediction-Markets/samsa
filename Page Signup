File 2 — Pages/signup.html
This is the signup page — Page 1 (signup form) and Page 2 (username creation)


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dobium — Sign Up</title>
  <link rel="stylesheet" href="../css/styles.css" />
</head>
<body class="auth-page">

  <!-- PAGE 1: Signup form -->
  <div id="page-signup" class="auth-card">
    <img src="../Logo-Title.png" alt="Dobium" class="auth-logo" />
    <h1>Join the Beta</h1>

    <form id="form-signup">
      <div class="field-row">
        <div class="field">
          <label>First Name</label>
          <input type="text" id="first-name" placeholder="First name" required />
        </div>
        <div class="field">
          <label>Last Name</label>
          <input type="text" id="last-name" placeholder="Last name" required />
        </div>
      </div>

      <div class="field">
        <label>Email Address</label>
        <input type="email" id="email" placeholder="you@email.com" required />
      </div>

      <div class="field">
        <label>Password</label>
        <input type="password" id="password" placeholder="Min. 8 characters" required minlength="8" />
      </div>

      <div class="field">
        <label>Are you a US Resident?</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="us-resident" value="yes" required /> Yes
          </label>
          <label class="radio-label">
            <input type="radio" name="us-resident" value="no" /> No
          </label>
        </div>
      </div>

      <p id="signup-error" class="error-msg"></p>
      <button type="submit" class="btn-primary">Signup to Beta</button>
    </form>

    <p class="auth-footer">Already have an account? <a href="./login.html">Log in</a></p>
  </div>

  <!-- PAGE 2: Username creation -->
  <div id="page-username" class="auth-card" style="display:none;">
    <img src="../Logo-Title.png" alt="Dobium" class="auth-logo" />
    <h1>Create Your Username</h1>
    <p class="auth-subtitle">Between 6 and 30 characters. No spaces.</p>

    <form id="form-username">
      <div class="field">
        <label>Enter Username</label>
        <input
          type="text"
          id="username"
          placeholder="e.g. tradingking"
          required
          minlength="6"
          maxlength="30"
          pattern="[a-zA-Z0-9_]+"
          title="Letters, numbers and underscores only"
        />
        <span class="field-hint">6–30 characters · letters, numbers, underscores only</span>
      </div>

      <p id="username-error" class="error-msg"></p>
      <button type="submit" class="btn-primary">Next</button>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="../config/supabase.js"></script>
  <script src="../js/features/auth/signup.js"></script>
</body>
</html>
