File 3 — Pages/login.html
This is the login page — Page 3 (username entry) and Page 4 (password)


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dobium — Login</title>
  <link rel="stylesheet" href="../css/styles.css" />
</head>
<body class="auth-page">

  <!-- PAGE 3: Beta Pass Login -->
  <div id="page-login-id" class="auth-card">
    <img src="../Logo-Title.png" alt="Dobium" class="auth-logo" />
    <h1>Beta Pass Login</h1>

    <form id="form-login-id">
      <div class="field">
        <label>Login ID</label>
        <input
          type="text"
          id="login-username"
          placeholder="Your username"
          required
          minlength="6"
          maxlength="30"
        />
      </div>

      <p id="login-id-error" class="error-msg"></p>
      <button type="submit" class="btn-primary">Continue</button>
    </form>

    <p class="auth-footer">Don't have an account? <a href="./signup.html">Sign up</a></p>
  </div>

  <!-- PAGE 4: Password -->
  <div id="page-password" class="auth-card" style="display:none;">
    <img src="../Logo-Title.png" alt="Dobium" class="auth-logo" />
    <h1>Welcome back</h1>
    <p class="auth-subtitle" id="welcome-name"></p>

    <form id="form-password">
      <div class="field">
        <label>Password</label>
        <input type="password" id="login-password" placeholder="Your password" required />
      </div>

      <p id="password-error" class="error-msg"></p>
      <button type="submit" class="btn-primary">Continue</button>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="../config/supabase.js"></script>
  <script src="../js/features/auth/login.js"></script>
</body>
</html>
