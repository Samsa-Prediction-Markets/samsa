// POST /api/markets — auth required
app.post(
  '/api/markets',
  authenticate,
  [
    body('title').isString().trim().isLength({ min: 5, max: 300 }),
    body('description').isString().trim().isLength({ min: 10, max: 2000 }),
    body('category').isString().trim().escape().isLength({ min: 2, max: 50 }),
    body('subcategory').optional().isString().trim().escape().isLength({ max: 50 }),
    body('closeAt').isISO8601().toDate(),
    body('outcomes').isArray({ min: 2, max: 10 }),
    body('outcomes.*').isString().trim().isLength({ min: 1, max: 100 }),
  ],
  validate,
  async (req, res) => {
    try {
      const { title, description, category, subcategory = '', closeAt, outcomes } = req.body;
      if (new Date(closeAt) <= new Date()) {
        return res.status(400).json({ error: 'closeAt must be in the future' });
      }
      const initialProb = 100 / outcomes.length;
      const market = await sequelize.transaction(async (t) => {
        const m = await Market.create(
          { title, description, category, subcategory, closeAt, probability: initialProb },
          { transaction: t }
        );
        await Outcome.bulkCreate(
          outcomes.map((label) => ({ marketId: m.id, label, probability: initialProb })),
          { transaction: t }
        );
        return Market.findByPk(m.id, { include: [Outcome], transaction: t });
      });
      res.status(201).json({ market });
    } catch (err) {
      console.error('Create market error:', err);
      res.status(500).json({ error: 'Failed to create market' });
    }
  }
);

// POST /api/markets/:id/resolve — admin only
app.post(
  '/api/markets/:id/resolve',
  authenticate,
  requireAdmin,
  [param('id').isUUID(), body('winOutcomeId').isUUID()],
  validate,
  async (req, res) => {
    try {
      const market = await Market.findByPk(req.params.id, {
        include: [Outcome, { model: Prediction, where: { status: 'open' }, required: false }],
      });
      if (!market) return res.status(404).json({ error: 'Market not found' });
      if (market.status !== 'active') return res.status(400).json({ error: 'Market already resolved' });
      const winOutcome = market.Outcomes.find((o) => o.id === req.body.winOutcomeId);
      if (!winOutcome) return res.status(400).json({ error: 'Invalid winOutcomeId' });

      await sequelize.transaction(async (t) => {
        await market.update(
          { status: 'resolved', resolvedAt: new Date(), winOutcomeId: winOutcome.id },
          { transaction: t }
        );
        for (const pred of market.Predictions || []) {
          const won = pred.outcomeId === winOutcome.id;
          const payout = won ? pred.amount / pred.entryProb : 0;
          await pred.update({ status: won ? 'won' : 'lost', payout }, { transaction: t });
          if (won && payout > 0) {
            await User.increment('balance', { by: payout, where: { id: pred.userId }, transaction: t });
            await Transaction.create(
              { userId: pred.userId, type: 'payout', amount: payout, note: `Won: ${market.title}` },
              { transaction: t }
            );
          }
        }
      });
      res.json({ ok: true });
    } catch (err) {
      console.error('Resolve market error:', err);
      res.status(500).json({ error: 'Failed to resolve market' });
    }
  }
);

