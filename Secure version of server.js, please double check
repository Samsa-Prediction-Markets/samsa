// POST /api/predictions — place a bet
app.post(
  '/api/predictions',
  authenticate,
  [
    body('marketId').isUUID(),
    body('outcomeId').isUUID(),
    body('amount').isFloat({ min: 0.01, max: 10000 }),
  ],
  validate,
  async (req, res) => {
    try {
      const { marketId, outcomeId, amount } = req.body;
      const prediction = await sequelize.transaction(async (t) => {
        // Lock user row to prevent race conditions on balance
        const user = await User.findByPk(req.user.userId, { lock: t.LOCK.UPDATE, transaction: t });
        if (!user) throw Object.assign(new Error('User not found'), { status: 404 });
        if (user.balance < amount) throw Object.assign(new Error('Insufficient balance'), { status: 400 });

        const market = await Market.findByPk(marketId, { include: [Outcome], lock: t.LOCK.UPDATE, transaction: t });
        if (!market) throw Object.assign(new Error('Market not found'), { status: 404 });
        if (market.status !== 'active') throw Object.assign(new Error('Market is not active'), { status: 400 });
        if (new Date() > new Date(market.closeAt)) throw Object.assign(new Error('Market is closed'), { status: 400 });

        const outcome = market.Outcomes.find((o) => o.id === outcomeId);
        if (!outcome) throw Object.assign(new Error('Outcome not found'), { status: 404 });

        // LMSR pricing
        const sharesArr = market.Outcomes.map((o) => o.shares);
        const outcomeIdx = market.Outcomes.findIndex((o) => o.id === outcomeId);
        const { purchased, newProbs, newShares } = lmsrBuy(sharesArr, market.liquidity, outcomeIdx, amount);

        // Deduct balance atomically
        await user.decrement('balance', { by: amount, transaction: t });

        // Update all outcome shares and probabilities
        for (let i = 0; i < market.Outcomes.length; i++) {
          await market.Outcomes[i].update(
            { shares: newShares[i], probability: newProbs[i] * 100 },
            { transaction: t }
          );
        }

        // Update market
        await market.update(
          { volume: market.volume + amount, probability: newProbs[outcomeIdx] * 100 },
          { transaction: t }
        );

        // Record transaction
        await Transaction.create(
          { userId: req.user.userId, type: 'bet', amount: -amount, note: `Bet on "${outcome.label}" in "${market.title}"` },
          { transaction: t }
        );

        return Prediction.create(
          { userId: req.user.userId, marketId, outcomeId, amount, shares: purchased, entryProb: newProbs[outcomeIdx], status: 'open' },
          { transaction: t }
        );
      });
      res.status(201).json({ prediction });
    } catch (err) {
      const status = err.status || 500;
      const msg = status < 500 ? err.message : 'Failed to place bet';
      if (status === 500) console.error('Place bet error:', err);
      res.status(status).json({ error: msg });
    }
  }
);

