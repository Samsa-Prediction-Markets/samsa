// ─── LMSR pricing ────────────────────────────────────────────────────────────
function lmsrProbabilities(sharesArr, b) {
  const exps = sharesArr.map((s) => Math.exp(s / b));
  const total = exps.reduce((a, e) => a + e, 0);
  return exps.map((e) => e / total);
}

function lmsrBuy(sharesArr, b, outcomeIdx, amount) {
  const probs = lmsrProbabilities(sharesArr, b);
  const price = Math.max(probs[outcomeIdx], 0.01);
  const purchased = amount / price;
  const newShares = sharesArr.map((s, i) => (i === outcomeIdx ? s + purchased : s));
  const newProbs = lmsrProbabilities(newShares, b);
  return { purchased, newProbs, newShares };
}

// ─── Auth middleware ──────────────────────────────────────────────────────────
function authenticate(req, res, next) {
  const header = req.headers.authorization || '';
  const token = header.startsWith('Bearer ') ? header.slice(7) : null;
  if (!token) return res.status(401).json({ error: 'Unauthorized' });
  try {
    req.user = jwt.verify(token, JWT_SECRET);
    next();
  } catch {
    res.status(401).json({ error: 'Invalid or expired token' });
  }
}

function requireAdmin(req, res, next) {
  if (req.user?.role !== 'admin') return res.status(403).json({ error: 'Forbidden' });
  next();
}

// ─── Validation error handler ────────────────────────────────────────────────
function validate(req, res, next) {
  const errors = validationResult(req);
  if (!errors.isEmpty()) return res.status(400).json({ errors: errors.array() });
  next();
}

