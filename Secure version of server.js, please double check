// POST /api/wallet/withdraw
app.post(
  '/api/wallet/withdraw',
  authenticate,
  [body('amount').isFloat({ min: 0.01 })],
  validate,
  async (req, res) => {
    try {
      const { amount } = req.body;
      const balance = await sequelize.transaction(async (t) => {
        // Lock user row to prevent race conditions
        const user = await User.findByPk(req.user.userId, { lock: t.LOCK.UPDATE, transaction: t });
        if (!user || user.balance < amount) throw Object.assign(new Error('Insufficient balance'), { status: 400 });
        await user.decrement('balance', { by: amount, transaction: t });
        await Transaction.create(
          { userId: req.user.userId, type: 'withdrawal', amount: -amount, note: 'Manual withdrawal' },
          { transaction: t }
        );
        return user.balance - amount;
      });
      res.json({ balance });
    } catch (err) {
      const status = err.status || 500;
      if (status === 500) console.error('Withdraw error:', err);
      res.status(status).json({ error: err.message || 'Withdrawal failed' });
    }
  }
);

