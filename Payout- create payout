
lib/payouts.js

'use strict';

/**
 * DOBIUM PAYOUT MODEL
 *
 * Runs ONCE when a market resolves (admin picks the winning outcome).
 * Loops through every prediction on that market and calculates:
 *   - Winners get: stake + profit (minus platform fee)
 *   - Losers get:  partial refund (never walk away empty)
 *   - Platform gets: 1% of winning side only
 *
 * Variables:
 *   S = stake (how much they trade)
 *   p = probability at time of their trade (stored as entryProb)
 *   f = platform fee = 1%
 */

const PLATFORM_FEE = 0.01;

function resolveMarket(predictions, winningOutcomeId) {
  const payouts = [];
  let totalPlatformRevenue = 0;

  for (const pred of predictions) {
    const S = pred.amount;
    const p = pred.entryProb;   // probability when they placed the trade
    const f = PLATFORM_FEE;
    const won = pred.outcomeId === winningOutcomeId;

    let userPayout;
    let platformCut;

    if (won) {
      // ── Winner ───────────────────────────────────────────────
      const profit = S * (1 - p) * (1 - f);
      userPayout   = round(S + profit);
      platformCut  = round(S * f * (1 - p));
    } else {
      // ── Loser — always gets partial refund ───────────────────
      userPayout  = round(S * p);
      platformCut = 0; // platform only earns on winning side
    }

    totalPlatformRevenue += platformCut;

    payouts.push({
      predictionId:    pred.id,
      userId:          pred.userId,
      won,
      stake:           S,
      entryProb:       p,
      payout:          userPayout,
      platformRevenue: platformCut,
    });
  }

  return {
    payouts,
    totalPlatformRevenue: round(totalPlatformRevenue),
  };
}

function round(n) {
  return Math.round(n * 100) / 100;
}

module.exports = { resolveMarket };
